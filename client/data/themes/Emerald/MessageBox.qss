QMessageBox {
    background: #101416;
}

QMessageBox QLabel {
    color: #c1d5de;
}

QPushButton {
    padding: 3px;
    font-size: 13px;
    border: 1px solid #49aac5;
    border-radius: 2px;
    background-color: #49aac5;
    color: #101416;
    margin-bottom: 2px;
    padding-left:   15px;
    padding-right:  15px;
}

QPushButton:pressed {
    border: 1px solid #49aac5;
    background-color: #101416;
    color: #c1d5de;
}
